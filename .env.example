# ===========================================
# ECS Platform - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ===========================================

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=ecs
DB_PASSWORD=ecs_dev_password
DB_NAME=ecs_platform

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change-this-to-a-random-secret-in-production

# ---- LLM API Keys ----
# Claude (Anthropic) - 主力模型
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxx

# OpenAI - 备用模型
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ---- 应用 ----
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ---- 平台 OAuth (可选，开发阶段用沙箱) ----
# 淘宝开放平台
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_SANDBOX=true

# 抖音开放平台
DOUYIN_APP_KEY=
DOUYIN_APP_SECRET=
DOUYIN_SANDBOX=true
