{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ecs/shared": ["./lib/shared/src/index"],
      "@ecs/core": ["./lib/core/src/index"],
      "@ecs/llm-gateway": ["./lib/llm-gateway/src/index"],
      "@ecs/base-adapter": ["./lib/adapters/base-adapter/src/index"]
    }
  },
  "include": ["src/**/*", "lib/**/*"],
  "exclude": ["node_modules", "dist"]
}
