{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd deploy && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd deploy && npm start",
    "healthcheckPath": "/api/v1/auth/login",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
