{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd packages/api && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd packages/api && node dist/main.js",
    "healthcheckPath": "/api/v1/auth/login",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  },
  "plugins": {
    "postgresql": {
      "version": "16"
    },
    "redis": {
      "version": "7"
    }
  },
  "env": {
    "PORT": "4000",
    "NODE_ENV": "production",
    "JWT_SECRET": "ae165b55a0391bd1d7d004da018da7f5283333b137d0630aa870d142ebd43cad",
    "DEEPSEEK_API_KEY": "sk-cc6d64f978164dc593beded983d74020"
  }
}
