{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd packages/api && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd packages/api && node dist/main.js",
    "healthcheckPath": "/api/v1/auth/login",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  },
  "plugins": {
    "postgresql": {
      "version": "16"
    },
    "redis": {
      "version": "7"
    }
  }
}
